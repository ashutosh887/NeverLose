# ─────────────────────────────────────────────────────────────────
# NeverLose — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Pine Labs Legacy API (EMI Calculator v3) ──────────────────────
# Auth: merchant_id + access_code in request body
# Dashboard: https://dashboardv2.pluralonline.com
PINE_LABS_LEGACY_URL=https://uat.pinepg.in
PINE_LABS_MERCHANT_ID=
PINE_LABS_ACCESS_CODE=

# ── Pine Labs New Plural API (Payment Gateway, Links, QR, Checkout)
# Auth: Bearer token from POST /api/auth/v1/token
PINE_LABS_PLURAL_URL=https://pluraluat.v2.pinepg.in
PINE_LABS_CLIENT_ID=
PINE_LABS_CLIENT_SECRET=

# ── AWS Bedrock (credentials provided at event) ───────────────────
# Workshop Studio provides temporary STS credentials — set all three.
# For long-term IAM credentials (production), leave AWS_SESSION_TOKEN blank.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=us-east-1

# ── Anthropic Direct API (fallback if Bedrock unavailable) ────────
ANTHROPIC_API_KEY=

# ── Mock Data Layer ───────────────────────────────────────────────
# Set true to skip ALL Pine Labs API calls (safe default for demo)
USE_MOCK=true

# ── Bedrock Model IDs ─────────────────────────────────────────────
# us-east-1 → use "us." prefix
# ap-south-1 → use "global." prefix (e.g. global.anthropic.claude-sonnet-4-6-v1)
BEDROCK_SUPERVISOR_MODEL=us.anthropic.claude-sonnet-4-6-20251001-v1:0
BEDROCK_SUB_AGENT_MODEL=us.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Payment Callback URL (redirect after hosted checkout) ─────────
# Pine Labs redirects customer here after payment success/failure.
PAYMENT_CALLBACK_URL=http://localhost:3000/payment-complete

# ── Frontend URL (for CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
