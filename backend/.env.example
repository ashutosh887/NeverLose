# ─────────────────────────────────────────────────────────────────
# NeverLose — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.
# ─────────────────────────────────────────────────────────────────

# ── Pine Labs Legacy API (EMI Calculator v3) ──────────────────────
# Auth: merchant_id + access_code in request body
# Dashboard: https://dashboardv2.pluralonline.com
PINE_LABS_LEGACY_URL=https://uat.pinepg.in
PINE_LABS_MERCHANT_ID=
PINE_LABS_ACCESS_CODE=

# ── Pine Labs New Plural API (Payment Gateway, Links, QR, Checkout)
# Auth: Bearer token from POST /api/auth/v1/token
PINE_LABS_PLURAL_URL=https://pluraluat.v2.pinepg.in
PINE_LABS_CLIENT_ID=
PINE_LABS_CLIENT_SECRET=

# ── AWS Bedrock (credentials provided at event) ───────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# ── Anthropic Direct API (fallback if Bedrock unavailable) ────────
ANTHROPIC_API_KEY=

# ── Mock Data Layer ───────────────────────────────────────────────
# Set true to skip ALL Pine Labs API calls (safe default for demo)
USE_MOCK=true

# ── Bedrock Model IDs (Global CRIS from ap-south-1) ──────────────
# Use global. prefix — NOT us. prefix
BEDROCK_SUPERVISOR_MODEL=global.anthropic.claude-sonnet-4-6-v1
BEDROCK_SUB_AGENT_MODEL=global.anthropic.claude-haiku-4-5-20251001-v1:0

# ── Frontend URL (for CORS) ───────────────────────────────────────
FRONTEND_URL=http://localhost:3000
